# Public client configuration. Never place a Supabase service-role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Trusted backend only — set these in apps/api/.env, never commit real keys.
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key

# Web frontend — set this in Vercel dashboard to point at your deployed API
VITE_API_URL=https://your-api.railway.app
