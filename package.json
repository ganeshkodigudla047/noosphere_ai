{
  "name": "noosphere-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @noosphere/web",
    "dev:web": "npm run dev --workspace @noosphere/web",
    "dev:mobile": "npm run start --workspace @noosphere/mobile",
    "build": "npm run build --workspace @noosphere/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.19"
  }
}
